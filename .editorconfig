root = true

# --- Default ---
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.{py,java,kt,cs,cpp,c,h}]
indent_size = 4

[{Makefile,*.mk,*.go}]
indent_style = tab
indent_size = 4

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = 80

[*.{json,json5,jsonc}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}]
indent_size = 2

[*.{html,css,scss,sass,less}]
indent_size = 2

[*.{sh,bash,zsh}]
indent_size = 2

[*.{toml,ini,env,env.*}]
indent_size = 2

[{package-lock.json,yarn.lock,pnpm-lock.yaml,*.min.js,*.min.css}]
indent_style = ignore
trim_trailing_whitespace = false
insert_final_newline = false
