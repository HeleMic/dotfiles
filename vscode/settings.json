{
  // window
  "window.commandCenter": false,
  "window.zoomLevel": 0,
  "window.titleSeparator": " — ",
  "window.title": "${rootName}${separator}${activeEditorShort}${separator}${profileName}",
  // explorer
  "explorer.confirmDelete": true,
  "explorer.confirmDragAndDrop": true,
  "explorer.sortOrder": "foldersNestsFiles",
  "explorer.compactFolders": false,
  // workbench
  "workbench.colorTheme": "Bearded Theme Solarized",
  "workbench.iconTheme": "bearded-icons",
  "workbench.activityBar.location": "hidden",
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.enablePreview": false,
  "workbench.editor.labelFormat": "default",
  "workbench.list.smoothScrolling": true,
  "workbench.tree.indent": 30,
  "workbench.layoutControl.enabled": false,
  "workbench.editor.alwaysShowEditorActions": false,
  "workbench.statusBar.visible": false,
  "workbench.fontAliasing": "antialiased",
  // breadcrumbs
  "breadcrumbs.enabled": false,
  // editor
  "editor.fontFamily": "Dank Mono, Operator Mono LIG, 'cascadia code'",
  "editor.fontSize": 22,
  "editor.fontLigatures": true,
  "editor.fontWeight": "bold",
  "editor.lineHeight": 1.8,
  "editor.letterSpacing": 0,
  "editor.cursorWidth": 3,
  "editor.cursorHeight": 30,
  "editor.cursorStyle": "line",
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "editor.formatOnType": true,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.smoothScrolling": true,
  "editor.renderLineHighlight": "all",
  "editor.renderWhitespace": "trailing",
  "editor.renderControlCharacters": true,
  "editor.renderFinalNewline": "on",
  "editor.renderLineHighlightOnlyWhenFocus": false,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.scrollbar.horizontalScrollbarSize": 0,
  "editor.largeFileOptimizations": true,
  "editor.linkedEditing": true,
  "editor.semanticHighlighting.enabled": false,
  "editor.minimap.enabled": false,
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always",
    "source.sortImports": "always",
    "source.sortAndRemoveImports": "always",
    "source.fixAll.prettier": "always",
    "source.fixAll.eslint": "always"
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "comment",
          "comment.block",
          "comment.block.documentation",
          "comment.line",
          "constant",
          "constant.character",
          "constant.character.escape",
          "constant.numeric",
          "constant.numeric.integer",
          "constant.numeric.float",
          "constant.numeric.hex",
          "constant.numeric.octal",
          "constant.other",
          "constant.regexp",
          "constant.rgb-value",
          "emphasis",
          "entity",
          "entity.name",
          "entity.name.class",
          "entity.name.function",
          "entity.name.method",
          "entity.name.section",
          "entity.name.selector",
          "entity.name.tag",
          "entity.name.type",
          "entity.other",
          "entity.other.attribute-name",
          "entity.other.inherited-class",
          "invalid",
          "invalid.deprecated",
          "invalid.illegal",
          "keyword",
          "keyword.control",
          "keyword.operator",
          "keyword.operator.new",
          "keyword.operator.assignment",
          "keyword.operator.arithmetic",
          "keyword.operator.logical",
          "keyword.other",
          "markup",
          "markup.bold",
          "markup.changed",
          "markup.deleted",
          "markup.heading",
          "markup.inline.raw",
          "markup.inserted",
          "markup.italic",
          "markup.list",
          "markup.list.numbered",
          "markup.list.unnumbered",
          "markup.other",
          "markup.quote",
          "markup.raw",
          "markup.underline",
          "markup.underline.link",
          "meta",
          "meta.block",
          "meta.cast",
          "meta.class",
          "meta.function",
          "meta.function-call",
          "meta.preprocessor",
          "meta.return-type",
          "meta.selector",
          "meta.tag",
          "meta.type.annotation",
          "meta.type",
          "punctuation.definition.string.begin",
          "punctuation.definition.string.end",
          "punctuation.separator",
          "punctuation.separator.continuation",
          "punctuation.terminator",
          "storage",
          "storage.modifier",
          "storage.type",
          "string",
          "string.interpolated",
          "string.other",
          "string.quoted",
          "string.quoted.double",
          "string.quoted.other",
          "string.quoted.single",
          "string.quoted.triple",
          "string.regexp",
          "string.unquoted",
          "strong",
          "support",
          "support.class",
          "support.constant",
          "support.function",
          "support.other",
          "support.type",
          "support.type.property-name",
          "support.variable",
          "variable",
          "variable.language",
          "variable.name",
          "variable.other",
          "variable.other.readwrite",
          "variable.parameter"
        ],
        "settings": {
          "fontStyle": ""
        }
      }
    ]
  },
  // files
  "files.autoSave": "onFocusChange",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.autoSaveDelay": 2000,
  "files.autoSaveWhenNoErrors": true,
  "files.eol": "\n",
  // terminal
  "terminal.integrated.fontFamily": "Dank Mono, Operator Mono LIG, 'cascadia code'",
  "terminal.integrated.fontSize": 18,
  "terminal.integrated.fontWeight": "bold",
  "terminal.integrated.lineHeight": 1.4,
  "terminal.integrated.letterSpacing": 0,
  "terminal.integrated.cursorWidth": 3,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.smoothScrolling": true,
  // github copilot
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false
  },
  // chat
  "chat.viewSessions.enabled": false,
  "chat.fontSize": 15,
  "chat.fontFamily": "Manrope",
  "chat.editor.fontSize": 14,
  // javascript/typescript
  "javascript.suggest.paths": false,
  "typescript.suggest.paths": false,
  // php
  "php.completion.parameters": "parentheses",
  "php.format.codeStyle": "Laravel",
  "php.suggest.basic": false,
  "php.validate.enable": true,
  "php.validate.executablePath": "/Users/michele/.config/herd-lite/bin/php"
}
